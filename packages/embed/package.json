{
  "name": "@tipitip/embed",
  "version": "0.0.1-alpha.0",
  "description": "Drop-in React component for per-paragraph cUSD tipping on Celo",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "viem": "^2",
    "wagmi": "^2"
  },
  "dependencies": {
    "react-markdown": "^9"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "celo",
    "cusd",
    "tipping",
    "minipay",
    "react",
    "tipitip"
  ]
}
