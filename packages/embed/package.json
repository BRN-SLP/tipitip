{
  "name": "@tipitip/embed",
  "version": "0.1.0",
  "description": "Drop-in React component for per-paragraph cUSD tipping on Celo. Add a tippable article block to any blog with two lines of code.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "react-markdown": "^9"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "celo",
    "cusd",
    "tipping",
    "minipay",
    "react",
    "tipitip",
    "writers",
    "content",
    "micropayments",
    "embed"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BRN-SLP/tipitip.git",
    "directory": "packages/embed"
  },
  "bugs": {
    "url": "https://github.com/BRN-SLP/tipitip/issues"
  },
  "homepage": "https://tipitip-sable.vercel.app"
}
